horizontal_alignment = 1
vertical_alignment = 1

[node name="Label9" type="Label" parent="." unique_id=404575975]
layout_mode = 1
anchors_preset = -1
anchor_right = 0.048
anchor_bottom = 0.024
offset_left = -5011.0
offset_top = 5862.0
offset_right = -2390.456
offset_bottom = 7247.448
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_fonts/font = SubResource("FontVariation_h5hlm")
theme_override_font_sizes/font_size = 70
text = "As there are different features and gameplay styles for each level,
each of the controls will be seperated pending the level:

Level One:
Up Key - Holding allows the player to walk up 
Left Key - Holding  allows the player to walk left 
Down Key - Holding allows the player to walk down 
Right Key -  Holding allows the player to walk right 
E - Pressing E allows the player to pick up item(s)
Level Two:
Up Key - Holding allows the player to walk up 
Down Key - Holding allows the player to walk down 
Space - Pressing Space will allow the player to \"roll\" the lootbox
Level Three:
Left Key - Holding allows the player to walk left
Right Key - Holding allows the player to walk right
Space - Pressing Space will allow the player to jump
E - Pressing E allows the player to interact with item(s)"
horizontal_alignment = 1
vertical_alignment = 1

