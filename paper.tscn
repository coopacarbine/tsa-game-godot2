[node name="Label7" type="Label" parent="." unique_id=435279336]
layout_mode = 1
anchors_preset = -1
anchor_right = 0.048
anchor_bottom = 0.024
offset_left = -4997.0
offset_top = 4362.0
offset_right = -2376.456
offset_bottom = 4436.448
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_fonts/font = SubResource("FontVariation_h5hlm")
theme_override_font_sizes/font_size = 70
text = "Operation: Butterfly is completely playable using a keyboard and
 mouse. Although there are three different playable characters
throughout levels, the keybinds are very similar throughout.
To start, you are given three options in the menu: START (start the 
game and cue the first sequence cutscene), OPTIONS (to either
mute the game's sound or lower/raise the brightness), and the QUIT
button (close out of the game entirely.) Pressing START will lead
the player into a cutscene that was designed to introduce the gamer
to our story and give them a full grasp on the task at hand. 
Getting into the first level, the player is prompted to find a vile and
escape the laboratory. Doing so successfully will lead you right
into our epic chase sequence in level two. You, as the player, will 
evade cars and will be granted powerups to assist you along the
way. Completing that level efficiently will bring you right into level
three, level three throws it back with a classic platformer game in 
which you have to reach the teleporter before it is too late. 
Completing all levels seamlessly will ensure success and 
permission to view the ending. As the credits and ending play, you
will be caught up with the future that the player will have officially
changed. (Important tip: this game was designed for success, if
something seems like it is there for a reason... it probably is!)"
horizontal_alignment = 1
vertical_alignment = 1

